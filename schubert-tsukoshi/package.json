{
  "name": "@industrial-algebra/schubert-tsukoshi",
  "version": "0.4.0",
  "description": "Pure TypeScript geometric access control via Schubert calculus — zero-dependency extraction of the Schubert Rust crate, with impossibility detection in the browser.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./protocols": {
      "types": "./dist/protocols/index.d.ts",
      "import": "./dist/protocols/index.js",
      "require": "./dist/protocols/index.cjs"
    },
    "./crypto": {
      "types": "./dist/crypto/index.d.ts",
      "import": "./dist/crypto/index.js",
      "require": "./dist/crypto/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/protocols/index.ts src/crypto/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts src/protocols/index.ts src/crypto/index.ts --format esm,cjs --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "access-control",
    "schubert-calculus",
    "grassmannian",
    "capabilities",
    "geometry",
    "rbac",
    "impossibility-detection",
    "littlewood-richardson"
  ],
  "license": "Apache-2.0",
  "author": "Industrial Algebra",
  "homepage": "https://schubert.industrialalgebra.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/Industrial-Algebra/Schubert",
    "directory": "schubert-tsukoshi"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "tsup": "^8.3.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.6.0"
  }
}
